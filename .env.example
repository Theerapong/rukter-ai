# Rukter.ai Product Twin
PORT=3017

# Fireworks OpenAI-compatible endpoint.
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_API_KEY=
FIREWORKS_MODEL=accounts/fireworks/models/deepseek-v4-flash
FIREWORKS_MODEL_FALLBACKS=accounts/fireworks/models/gpt-oss-20b
FIREWORKS_VISION_MODEL=accounts/fireworks/models/kimi-k2p6
# Switch to an accessible Gemma vision deployment when Fireworks enables it for the account.
GEMMA_VISION_MODEL=
FIREWORKS_REQUEST_TIMEOUT_MS=24000
FIREWORKS_TOTAL_TIMEOUT_MS=27000
FIREWORKS_MAX_TOKENS=2048

# Optional evidence fields when running on AMD Developer Cloud.
AMD_CLOUD_INSTANCE=
AMD_GPU_NAME=
ROCM_VERSION=

# AMD Cinematic uses one FIFO queue so two jobs never share a GPU lifecycle.
AMD_GPU_QUEUE_MAX_SIZE=25
AMD_GPU_CAPACITY_POLL_MS=30000
AMD_GPU_PERSISTENT_TAG=rukter-product-story-persistent

# Optional AMD GPU multi-view reconstruction worker. Leave empty for truthful 2.5D previews.
AMD_3D_WORKER_URL=
AMD_3D_WORKER_TOKEN=

# Optional links displayed in the UI.
RUKTER_DASHBOARD_URL=https://store-4.rukter.com/dashboard/theme
RUKTER_CANONICAL_URL=https://rukter.com

# Optional MCP backend token. Production sets this only as a masked GitLab CI/CD variable;
# Terraform mounts it into the DigitalOcean App Platform runtime as a secret.
RUKTER_MCP_URL=https://rukter.com/mcp
RUKTER_MCP_ACCESS_TOKEN=
